# ── Shield Gateway ────────────────────────────────────────────────────────────
# Secret used to sign and verify all JWTs (auth tokens + session tokens).
# Generate with: openssl rand -hex 32
SHIELD_JWT_SECRET=dev-secret-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Async URL for the gateway service (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://shield:shield@db/shield

# Synchronous URL for the registry service (psycopg2 driver) and Alembic
ALEMBIC_DATABASE_URL=postgresql://shield:shield@db/shield

# ── Asset Storage ─────────────────────────────────────────────────────────────
# "local" stores files on the container filesystem; "s3" uses AWS S3.
ASSET_STORAGE_BACKEND=local

# Required when ASSET_STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/app/storage
REGISTRY_BASE_URL=http://registry:8002

# Required when ASSET_STORAGE_BACKEND=s3
AWS_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Inter-service URLs (docker-compose defaults) ──────────────────────────────
REGISTRY_SERVICE_URL=http://registry:8002
POLICY_SERVICE_URL=http://policy:8001

# ── Next.js Dashboard ─────────────────────────────────────────────────────────
# Public gateway URL reachable from the browser (not the internal docker hostname)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
NEXT_PUBLIC_CLIENT_ID=test-tool
NEXT_PUBLIC_CLIENT_SECRET=test-secret
NEXT_PUBLIC_RIGHTS_HOLDER_ID=test-rights-holder
